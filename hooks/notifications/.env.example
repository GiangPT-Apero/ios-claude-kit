# iOS Claude Kit — Notification Providers
# Copy to .env and fill in credentials for the providers you want.
# Priority: process.env > ~/.claude/.env > .claude/.env

# ============================================
# Telegram Notifications
# ============================================
# 1. Create bot via @BotFather → get token
# 2. Get chat_id: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============================================
# Slack Notifications
# ============================================
# 1. api.slack.com/apps → Create New App → Incoming Webhooks → Add to Workspace
SLACK_WEBHOOK_URL=

# ============================================
# Discord Notifications
# ============================================
# Server Settings → Integrations → Webhooks → New Webhook → Copy URL
DISCORD_WEBHOOK_URL=
